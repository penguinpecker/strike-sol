# ───────────────────────────────────────────────────────────────────────────
# STRIKE (Avalanche) environment
# Copy to .env.local and fill in. All NEXT_PUBLIC_* vars are exposed to the browser.
# ───────────────────────────────────────────────────────────────────────────

# Avalanche C-Chain RPC (chainId 43114). The public endpoint works for everything — ~1s blocks,
# no key. Point both at a dedicated endpoint later if you want private infra.
NEXT_PUBLIC_AVAX_RPC=https://api.avax.network/ext/bc/C/rpc
# Optional server-only RPC override for the read routes (balance reads, DataStore config, etc.).
# AVAX_RPC=

# Trading mode:
#   "paper" — local bankroll, real prices, NO on-chain settlement (default; safe demo)
#   "live"  — real GMX v2 perps signed by the user's Privy EVM wallet
NEXT_PUBLIC_STRIKE_MODE=paper

# Market the tap screen trades. One of the keys in lib/gmx/networks.ts MARKETS.
NEXT_PUBLIC_MARKET=BTC/USD

# Chart/settlement price source: "gmx" (default; the Chainlink Data Streams mirror GMX keepers
# fill against) | "binance" (smoother but drifts from the on-chain fill — demo aesthetics only).
NEXT_PUBLIC_PRICE_FEED=gmx

# Platform fee charged on the STAKE when OPENING a live call (default 0.0069 = 0.69%). Collected
# on-chain in the same open tx (a sendWnt leg pays the treasury in WAVAX). Set 0 to disable.
NEXT_PUBLIC_STRIKE_FEE_RATE=0.0069
# Where the fee lands (plain EVM address). Defaults to the STRIKE deployer/ops wallet. Empty/zero
# skips the fee. The treasury receives WAVAX (wrapped AVAX) — unwrap when sweeping.
NEXT_PUBLIC_STRIKE_TREASURY=0x3377a17625ea82155d2508e48904bee4f562829e

# Privy 𝕏 OAuth login. When set, real X login activates and an EVM embedded wallet is created on
# login; otherwise a prototype handle-entry flow is used. Create at dashboard.privy.io → enable
# Twitter login → add your domains to "Allowed origins", and enable EVM embedded wallets.
NEXT_PUBLIC_PRIVY_APP_ID=

# GO-LIVE GATE. Even in mode "live", NO transaction is broadcast unless this is exactly "true".
# With it off, live-mode taps validate the exact tx against mainnet (eth_call) and send nothing.
# Flip to "true" only when you are ready to trade for real.
NEXT_PUBLIC_STRIKE_LIVE_BROADCAST=false

# ── Supabase (persistence: players + settled calls + leaderboard) — optional ──────────────────
# When unset, the app runs fine and simply doesn't persist. The client uses the public URL + anon
# key; the SERVER uses the secret key (write-only, never exposed to the browser, never committed).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SECRET_KEY=
